{
  "info": {
    "name": "Real-Time Chat App",
    "description": "API endpoints for the Real-Time Chat Application",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "1. Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if(jsonData.token) {",
                  "    pm.environment.set(\"jwt_token\", jsonData.token);",
                  "    pm.environment.set(\"user_id\", jsonData.userId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"testuser1\",\n    \"email\": \"test1@example.com\",\n    \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:9090/api/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "9090",
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "2. Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if(jsonData.token) {",
                  "    pm.environment.set(\"jwt_token\", jsonData.token);",
                  "    pm.environment.set(\"user_id\", jsonData.userId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"test1@example.com\",\n    \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:9090/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "9090",
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Chats",
      "item": [
        {
          "name": "3. Create Chat",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if(jsonData.id) {",
                  "    pm.environment.set(\"chat_id\", jsonData.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"chatName\": \"My First Chat Room\",\n    \"groupChat\": false,\n    \"users\": [\n        \"{{user_id}}\",\n        \"REPLACE_WITH_ANOTHER_USER_ID\"\n    ]\n}"
            },
            "url": {
              "raw": "http://localhost:9090/api/chats",
              "protocol": "http",
              "host": ["localhost"],
              "port": "9090",
              "path": ["api", "chats"]
            }
          }
        },
        {
          "name": "4. Get User Chats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:9090/api/chats/user/{{user_id}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "9090",
              "path": ["api", "chats", "user", "{{user_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Messages",
      "item": [
        {
          "name": "5. Get Chat Messages",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:9090/api/messages/{{chat_id}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "9090",
              "path": ["api", "messages", "{{chat_id}}"]
            }
          }
        }
      ]
    }
  ]
}
